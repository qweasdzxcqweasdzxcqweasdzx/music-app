# ===========================================
# Ultimate Music App Configuration
# ===========================================
# Скопируйте этот файл в .env и заполните значения

# ===========================================
# Приложение
# ===========================================
APP_NAME=Ultimate Music App
DEBUG=True

# Сервер
HOST=0.0.0.0
PORT=8000

# ===========================================
# База данных
# ===========================================
# MongoDB (локально или Docker)
MONGODB_URL=mongodb://mongo:27017
DB_NAME=ultimate_music_app

# Redis (локально или Docker)
REDIS_URL=redis://redis:6379

# ===========================================
# Безопасность
# ===========================================
# Сгенерируйте случайную строку 32+ символов
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-characters-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# Telegram Bot
# ===========================================
# Получить в @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ===========================================
# SoundCloud API
# ===========================================
# https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://localhost:8000/callback/soundcloud

# ===========================================
# VK API (резерв)
# ===========================================
# https://dev.vk.com/
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ===========================================
# YouTube API
# ===========================================
# https://console.cloud.google.com/apis
YOUTUBE_API_KEY=

# ===========================================
# Navidrome / Subsonic (своя коллекция)
# ===========================================
# URL вашего Navidrome сервера
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USERNAME=
NAVIDROME_PASSWORD=
# Или JWT токен (Navidrome 0.47+)
NAVIDROME_JWT_TOKEN=

# ===========================================
# AI Сервисы - Генерация музыки
# ===========================================

# Suno AI (генерация песен по промпту)
# https://suno.com
SUNO_API_KEY=

# Mubert (фоновая музыка)
# https://mubert.com
MUBERT_CLIENT_ID=
MUBERT_TOKEN=

# Hugging Face (MusicGen и другие модели)
# https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Replicate (разные AI модели)
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ===========================================
# AI Сервисы - Обработка аудио
# ===========================================

# LALAL.AI (разделение на стемы)
# https://www.lalal.ai/api/
LALAL_API_KEY=

# ElevenLabs (синтез речи/вокала)
# https://elevenlabs.io
ELEVENLABS_API_KEY=

# ===========================================
# Genius API (тексты песен)
# ===========================================
# https://genius.com/api-clients
GENIUS_API_TOKEN=

# ===========================================
# Прокси
# ===========================================
# Для обхода региональных ограничений
PROXY_URL=

# ===========================================
# Настройки миксера
# ===========================================
# Предпочтительный источник: auto, soundcloud, navidrome
MIXER_PREFERRED_SOURCE=auto
# Разрешить AI генерацию в миксе
MIXER_ENABLE_AI=True

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===========================================
# Кэширование (TTL в секундах)
# ===========================================
CACHE_TTL_DEFAULT=3600
CACHE_TTL_TRACK=86400
CACHE_TTL_ARTIST=43200

# ===========================================
# Анти-цензура
# ===========================================
PREFER_ORIGINAL=True
AUTO_REPLACE_CENSORED=True

# ===========================================
# Рекомендации
# ===========================================
RECOMMENDATIONS_MIN_TRACKS=10
RECOMMENDATIONS_MAX_TRACKS=50
